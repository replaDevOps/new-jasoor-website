{
  "rewrites": [
    {
      "source": "/graphql",
      "destination": "https://verify.jusoor-sa.co/graphql"
    },
    {
      "source": "/subscriptions",
      "destination": "https://verify.jusoor-sa.co/subscriptions"
    },
    {
      "source": "/((?!graphql|subscriptions|assets|_next).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}